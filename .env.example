# Puerto interno de Node-RED (no cambiar salvo conflicto)
PORT=1880
DASH_PORT=1881

# ---- Red del laboratorio ------------------------------------------------
# Subred a escanear con nmap
SUBNET=192.168.1.0/24

# IP del equipo administrador (queda excluida del mapa de dispositivos)
MY_PC_IP=192.168.1.218

# ---- Router OpenWrt -----------------------------------------------------
# IP del router en la LAN
ROUTER_IP=192.168.1.1

# Contraseña SSH del router (usuario root por defecto en OpenWrt)
ROUTER_PASS=tu_password_ssh_del_router

# ---- Nota sobre valores hardcodeados en flows.json ----------------------
# ROUTER_IP y ROUTER_PASS están actualmente hardcodeados dentro de flows.json
# en los nodos de función SSH. Para una nueva instalación debes actualizarlos
# directamente en el editor Node-RED (ver sección "Configurar credenciales"
# en el README).
